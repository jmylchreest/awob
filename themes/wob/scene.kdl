// awob "wob" theme.
//
// Pixel-faithful clone of upstream wob's default look: black background,
// white border, white-on-black bar fill. Geometry mirrors wob's defaults
// (width 400, height 50, border_size 4, border_offset 4, bar_padding 4).
//
// Colour-theming model matches wob exactly. wob's CLI / config exposes
// three independent colour knobs (background, border, bar) plus a
// parallel set for the overflow state, plus per-style overrides of all
// three. The palette + styles below mirror that model so existing
// wob users feel at home and named-style scripts work unchanged.

palette {
    // Wob's three base colours (background_color, border_color,
    // bar_color in upstream's config.c).
    bg     "#000000"
    border "#ffffff"
    bar    "#ffffff"

    // Wob's overflow colours (when value > max). Upstream defaults
    // are #FF000000 background + red border + red bar. Awob doesn't
    // auto-detect the overflow case yet — see the "overflow" style
    // below for manual application; FUTURES.md tracks auto-apply.
    overflow_bg     "#000000"
    overflow_border "#ff0000"
    overflow_bar    "#ff0000"
}

styles {
    // Wob's per-style colour overrides. Each named style on stdin
    // (`<value> <style>` lines) selects a colour set; in the upstream
    // wob config users write
    //
    //     [style.critical]
    //     background_color = ...
    //     border_color     = ...
    //     bar_color        = ...
    //
    // and the matching block in awob is the equivalent. For pixel-
    // faithful wob, every named style uses the base colours — wob
    // ships no colour-coded styles out of the box. Customise below:
    // e.g. `style "critical" bar="#ff0000" border="#ff0000"`.
    style "low"      bg="$bg" border="$border" bar="$bar"
    style "normal"   bg="$bg" border="$border" bar="$bar"
    style "warn"     bg="$bg" border="$border" bar="$bar"
    style "critical" bg="$bg" border="$border" bar="$bar"
    style "muted"    bg="$bg" border="$border" bar="$bar"

    // Wob's overflow state. Auto-applied by the daemon when
    // `value > max`, matching upstream wob's behaviour. Override
    // the overflow_* palette keys above for a different overflow
    // look; this block just plumbs them through to the bg / border
    // / bar bindings the scene reads.
    style "overflow" bg="$overflow_bg" border="$overflow_border" bar="$overflow_bar"
}

// Geometry matches upstream wob's defaults (config.c):
//   width=400, height=50, border_size=4, border_offset=4, bar_padding=4
//   timeout=1000ms, anchor=<unset> (center of the output), margin=0
//   background_color=#FF000000, bar_color=#FFFFFFFF, border_color=#FFFFFFFF
surface {
    width 400
    height 50
    anchor "center"
    fade-in  "0ms"
    show     "1000ms"
    fade-out "0ms"
}

scene {
    // Background plate.
    rect z=0 x=0 y=0 width="100%" height="100%" fill="$bg"

    // White border. Drawn as a fill 4px inside the surface; the next
    // rect (inner background) covers everything except the visible frame.
    rect z=1 x=4 y=4 width="100%-8" height="100%-8" fill="$border"

    // Inner black area (between the border and the bar padding).
    rect z=2 x=8 y=8 width="100%-16" height="100%-16" fill="$bg"

    // The bar fill: inset by border_offset (4) + border (4) + bar_padding (4)
    // = 12 px on each side, value-driven width.
    bar z=3 x=12 y=12 width="100%-24" height="100%-24" \
        fill="$bar" \
        min=0 max="$max" value="$value" from="{$lastValue ?? $value}" \
        transition="width 180ms linear"
}
