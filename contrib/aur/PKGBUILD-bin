# Maintainer: John Mylchreest <jmylchreest@gmail.com>
#
# AUR binary package: pulls the prebuilt release tarball from
# GitHub Releases. @VERSION@ and @SHA256@ are filled in at publish
# time by the release workflow (see .github/workflows/release.yml,
# eventually). Until automation lands, render manually with:
#
#   sed -e 's/@VERSION@/0.0.1/' -e "s/@SHA256@/$(sha256sum awob-*.tar.gz | cut -d' ' -f1)/" \
#       contrib/aur/PKGBUILD-bin > /tmp/awob-bin/PKGBUILD

pkgname=awob-bin
pkgver=@VERSION@
pkgrel=1
pkgdesc="Another Wayland Overlay Bar — drop-in replacement for wob with richer theming and typed IPC."
arch=('x86_64')
url="https://github.com/jmylchreest/awob"
license=('MIT')
depends=('fontconfig' 'freetype2' 'pipewire' 'dbus' 'libudev.so')
optdepends=(
    'pactl: volume / mute keybinds'
    'brightnessctl: brightness keybinds'
)
provides=('awob' 'awob-daemon')
conflicts=('awob' 'awob-git')
source=("awob-${pkgver}-x86_64-unknown-linux-gnu.tar.gz::https://github.com/jmylchreest/awob/releases/download/v${pkgver}/awob-${pkgver}-x86_64-unknown-linux-gnu.tar.gz")
sha256sums=('@SHA256@')

package() {
    cd "awob-${pkgver}-x86_64-unknown-linux-gnu"

    # Binaries.
    install -Dm755 -t "${pkgdir}/usr/bin" \
        bin/awob \
        bin/awob-daemon \
        bin/awob-listener-pipewire \
        bin/awob-listener-battery \
        bin/awob-listener-backlight \
        bin/awob-listener-keyboard-backlight \
        bin/awob-listener-wob

    # Default themes + shared palettes. Daemon's themes_dir defaults
    # to ~/.config/awob/themes; users who want the stock themes copy
    # them in or symlink. Packagers may prefer to install to
    # /usr/share/awob/themes — adjust if you rebuild this PKGBUILD.
    install -dm755 "${pkgdir}/usr/share/awob"
    cp -r share/awob/themes "${pkgdir}/usr/share/awob/"

    # systemd user unit.
    install -Dm644 lib/systemd/user/awob.service \
        "${pkgdir}/usr/lib/systemd/user/awob.service"

    # Licence + readme.
    install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
    install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
}
